// Variables
$primary-color: #2c3e50;
$text-color: #555;
$light-text: #7f8c8d;
$accent-color: #3498db;
$border-radius: 16px;
$transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
$shadow: 0 4px 12px rgba(0, 0, 0, 0.08);
$shadow-hover: 0 15px 30px rgba(0, 0, 0, 0.15);

// Contenedor principal
:host {
  display: block;
  background: #f5f6fa;
  min-height: 100vh;
  padding: 40px 20px;
}

// Contenedor general
.about-container {
  max-width: 900px;
  margin: 0 auto;
}

// Estilos de secciones
section {
  background: #ffffff;
  border-radius: $border-radius;
  padding: 30px;
  margin-bottom: 30px;
  box-shadow: $shadow;
  transition: $transition;

  &:hover {
    box-shadow: $shadow-hover;
    transform: translateY(-5px);
  }
}

// Títulos principales
h1 {
  color: $primary-color;
  font-size: 1.8rem;
  margin: 0 0 15px 0;
  font-weight: 800;
}

// Párrafos
p {
  color: $light-text;
  font-size: 1rem;
  line-height: 1.6;
  margin: 10px 0;
  font-weight: 500;
}

// Sección de contacto
.contact-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  flex-wrap: wrap;

  a {
    text-decoration: none;
    display: inline-block;
    transition: $transition;

    img {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      border: 2px solid #eee;
      box-shadow: $shadow;
      transition: $transition;

      &:hover {
        border-color: $accent-color;
        box-shadow: $shadow-hover;
        transform: scale(1.1);
      }
    }
  }
}

// Footer
footer {
  background: #ffffff;
  border-radius: $border-radius;
  padding: 25px;
  text-align: center;
  margin-top: 40px;
  box-shadow: $shadow;
  border-top: 3px solid $accent-color;

  p {
    margin: 8px 0;
    font-size: 0.95rem;

    &:first-child {
      color: $primary-color;
      font-weight: 700;
    }
  }
}

// Responsive design
@media (max-width: 768px) {
  :host {
    padding: 20px 15px;
  }

  section {
    padding: 20px;
    margin-bottom: 20px;
  }

  h1 {
    font-size: 1.4rem;
  }

  p {
    font-size: 0.95rem;
  }

  .contact-section {
    a {
      img {
        width: 60px;
        height: 60px;
      }
    }
  }

  footer {
    padding: 20px;

    p {
      font-size: 0.9rem;
    }
  }
}

@media (max-width: 480px) {
  :host {
    padding: 15px 10px;
  }

  section {
    padding: 15px;
    margin-bottom: 15px;
  }

  h1 {
    font-size: 1.2rem;
  }

  p {
    font-size: 0.9rem;
  }

  .contact-section {
    a {
      img {
        width: 50px;
        height: 50px;
      }
    }
  }
}
</file>

