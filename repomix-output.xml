$primary: #2c3e50;
$accent: #3498db;
$danger: #e74c3c;
$success: #27ae60;
$light-bg: #f5f6fa;
$card-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
$transition: all 0.25s cubic-bezier(0.25, 0.8, 0.25, 1);

:host {
  display: block;
  background: $light-bg;
  min-height: 100vh;
  padding: 32px 20px;
}

.profile-page {
  max-width: 680px;
  margin: 0 auto;
}

// Banner de perfil
.profile-banner {
  display: flex;
  align-items: center;
  gap: 22px;
  margin-bottom: 28px;
  padding: 28px 30px;
  background: linear-gradient(135deg, #2c3e50 0%, #3498db 100%);
  border-radius: 20px;
  color: #fff;
  box-shadow: 0 8px 32px rgba(52, 152, 219, 0.3);

  .avatar-ring {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    border: 3px solid rgba(255, 255, 255, 0.5);
    padding: 3px;
    flex-shrink: 0;

    .avatar {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      font-weight: 800;
      color: #fff;
      letter-spacing: -1px;
    }
  }

  .banner-info {
    h1 {
      margin: 0 0 6px;
      font-size: 1.6rem;
      font-weight: 800;
      line-height: 1.1;
    }

    .email-pill {
      display: inline-block;
      background: rgba(255, 255, 255, 0.18);
      border: 1px solid rgba(255, 255, 255, 0.3);
      padding: 3px 12px;
      border-radius: 20px;
      font-size: 0.82rem;
      opacity: 0.9;
    }
  }
}

// Tarjeta principal
.profile-card {
  background: #fff;
  border-radius: 20px;
  box-shadow: $card-shadow;
  overflow: hidden;
}

// Secciones
.profile-section {
  padding: 26px 30px;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18px;

  h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: $primary;
  }

  .btn-edit-toggle {
    background: none;
    border: 1.5px solid #dde;
    color: $accent;
    padding: 5px 14px;
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: $transition;

    &:hover {
      background: #eef8ff;
      border-color: $accent;
    }
  }
}

.divider {
  border: none;
  border-top: 1px solid #f0f0f5;
  margin: 0;
}

// Info grid (vista)
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.info-item {
  label {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #95a5a6;
    margin-bottom: 4px;
  }
  p {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 600;
    color: $primary;
  }
}

.muted-hint {
  margin: 0;
  color: #bdc3c7;
  font-size: 0.9rem;
}

// Formularios
.edit-form {
  display: flex;
  flex-direction: column;
  gap: 14px;

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .form-group {
    display: flex;
    flex-direction: column;

    label {
      font-size: 0.8rem;
      font-weight: 700;
      color: #555;
      margin-bottom: 6px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    input {
      padding: 10px 13px;
      border: 1.5px solid #dde;
      border-radius: 9px;
      font-size: 0.92rem;
      color: $primary;
      background: #fff;
      transition: border-color 0.2s;

      &:focus {
        border-color: $accent;
        outline: none;
        box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.12);
      }
    }

    .field-error {
      margin-top: 5px;
      font-size: 0.76rem;
      color: $danger;
    }
  }
}

.form-actions {
  display: flex;
  gap: 10px;
  margin-top: 4px;

  button {
    padding: 10px 22px;
    border-radius: 9px;
    font-weight: 700;
    font-size: 0.88rem;
    cursor: pointer;
    border: none;
    transition: $transition;
  }

  .btn-save {
    background: $success;
    color: #fff;
    &:hover:not(:disabled) { background: darken($success, 8%); }
    &:disabled { background: #bdc3c7; cursor: not-allowed; }
  }

  .btn-cancel {
    background: $light-bg;
    color: #7f8c8d;
    border: 1.5px solid #dde;
    &:hover { background: #e8e8ee; }
  }
}

// Favoritos
.fav-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 10px;
}

.fav-chip {
  display: flex;
  align-items: center;
  gap: 8px;
  background: $light-bg;
  border: 1.5px solid #e8e8f0;
  border-radius: 30px;
  padding: 5px 14px 5px 7px;
  transition: $transition;

  &:hover {
    border-color: #f5b7b1;
    background: #fdedec;
  }

  img {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: contain;
    background: #e8e8f0;
  }

  span {
    font-size: 0.85rem;
    font-weight: 600;
    color: $primary;
  }
}

.fav-count {
  margin: 0;
  font-size: 0.82rem;
  color: #95a5a6;
}

// Zona peligrosa
.danger-zone {
  .btn-logout {
    background: #fdedec;
    color: $danger;
    border: 1.5px solid #f5b7b1;
    padding: 10px 22px;
    border-radius: 9px;
    font-weight: 700;
    font-size: 0.88rem;
    cursor: pointer;
    transition: $transition;

    &:hover {
      background: $danger;
      color: #fff;
      border-color: $danger;
    }
  }
}

// Responsive
@media (max-width: 600px) {
  :host { padding: 16px 12px; }

  .profile-banner {
    flex-direction: column;
    text-align: center;
    padding: 24px 20px;

    .banner-info h1 { font-size: 1.3rem; }
  }

  .profile-section { padding: 20px; }

  .info-grid,
  .edit-form .form-row {
    grid-template-columns: 1fr;
  }
}
