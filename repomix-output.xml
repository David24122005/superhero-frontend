            <div class="form-group">
              <label>Fortaleza</label>
              <input type="text" [(ngModel)]="editData.fortaleza" name="fortaleza" />
            </div>
            <div class="form-group">
              <label>Resistencia</label>
              <input type="text" [(ngModel)]="editData.resistencia" name="resistencia" />
            </div>
          </div>
          <div class="form-group full-width">
