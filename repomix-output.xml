    <!-- Cuerpo -->
    <div class="modal-body">

      <!-- MODO VISTA -->
      @if (!editMode) {
        <div class="stats-grid">
          <div class="stat-card poder">
            <span class="stat-icon">⚡</span>
            <div class="stat-info">
              <label>Superpoder</label>
              <p>{{ hero.poder }}</p>
            </div>
          </div>
          <div class="stat-card fortaleza">
            <span class="stat-icon">🛡️</span>
            <div class="stat-info">
              <label>Fortaleza</label>
              <p>{{ hero.fortaleza || 'Desconocida' }}</p>
            </div>
          </div>
          <div class="stat-card resistencia">
            <span class="stat-icon">💪</span>
            <div class="stat-info">
              <label>Resistencia</label>
              <p>{{ hero.resistencia || 'Desconocida' }}</p>
            </div>
          </div>
          <div class="stat-card debilidad">
            <span class="stat-icon">⚠️</span>
            <div class="stat-info">
              <label>Debilidad</label>
              <p>{{ hero.debilidad || 'Desconocida' }}</p>
            </div>
          </div>
        </div>

        <!-- Botones de acción vista -->
        <div class="modal-actions">
          <button class="btn-fav" (click)="toggleFav()" [class.active]="hero.esFavorito">
            {{ hero.esFavorito ? '❤️ En favoritos' : '🤍 Añadir a favoritos' }}
          </button>
          @if (isLoggedIn) {
