<div class="modal-backdrop" (click)="onBackdropClick($event)">
  <div class="modal-panel" role="dialog" aria-modal="true" [attr.aria-label]="hero.nombre">

    <!-- Header con imagen -->
    <div class="modal-hero-header">
      <img
        [src]="'assets/images/' + hero.imagen_url"
        [alt]="hero.nombre"
        class="hero-portrait"
        (error)="onImgError($event)"
      />
